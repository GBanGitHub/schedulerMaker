{
  "name": "schedule-maker",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @schedule-maker/database db:generate",
    "db:push": "pnpm --filter @schedule-maker/database db:push",
    "db:migrate": "pnpm --filter @schedule-maker/database db:migrate",
    "db:studio": "pnpm --filter @schedule-maker/database db:studio",
    "db:seed": "pnpm --filter @schedule-maker/database db:seed"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
